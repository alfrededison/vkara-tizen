# vkara monorepo — copy to apps/api/.env and apps/web/.env (or symlink) for local dev.
# Do not commit secrets. See packages/env/src/flags.ts (VKARA_ENV_DOCS) for VKARA_* docs.

# --- API (apps/api) ---
NODE_ENV=development
PORT=8000

PUBLIC_APP_URL=http://localhost:3000
# APP_PUBLIC_URL=
# WEB_ORIGIN=
# CORS_ORIGINS=http://localhost:3000,https://vkara.example.com

# Embed playability (true|false|1|0|yes|no|on|off — unset = default off)
# VKARA_EMBED_PREFILTER_AT_LIST=false
# VKARA_EMBED_CACHE_TTL_SECONDS=2592000

REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

EMPTY_ROOM_TIMEOUT=3600
# SERVICE_REPORT_CRON=0 * * * *

LOG_TO_FILES=false
LOG_LEVEL=info
ERROR_LOG_PATH=logs/error.log
COMBINED_LOG_PATH=logs/combined.log

# --- Sentry (org: vkara) ---
# DSNs are public client keys. Auth token is a secret (source maps / releases only).
# Projects: https://vkara.sentry.io/projects/
#
# API → project vkara-api
# SENTRY_DSN=https://79949b8cf4366a0faae06a8099585e19@o4511749689901056.ingest.us.sentry.io/4511749708120064
# SENTRY_ENVIRONMENT=development
# SENTRY_RELEASE=
# SENTRY_TRACES_SAMPLE_RATE=1.0
# SENTRY_LOG_LEVELS=info,warn,error
# SENTRY_ENABLED=true
# SENTRY_VERIFY=1
#
# Web → project vkara-web (browser + Next server/edge)
# NEXT_PUBLIC_SENTRY_DSN=https://9486059e287181cacf72326c9bac8a43@o4511749689901056.ingest.us.sentry.io/4511749707792384
# SENTRY_DSN=https://9486059e287181cacf72326c9bac8a43@o4511749689901056.ingest.us.sentry.io/4511749707792384
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=1.0
# NEXT_PUBLIC_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0.1
# NEXT_PUBLIC_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=1.0
# Build-time source maps (https://vkara.sentry.io/settings/auth-tokens/)
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=vkara
# SENTRY_PROJECT=vkara-web

# --- Web (apps/web) ---
NEXT_PUBLIC_API_URL=http://localhost:8000
# NEXT_PUBLIC_TIKTOK_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=
# NEXT_PUBLIC_CLOUDFLARE_WEB_ANALYTICS_TOKEN=

# VKARA_EXPERIMENTS=false
# NEXT_PUBLIC_VKARA_EXPERIMENTS=false

# Dev/WSL only — fixes UNKNOWN_CERTIFICATE_VERIFICATION_ERROR on some hosts.
# VKARA_TLS_INSECURE=true

# Playwright proxy (api-redis / TikTok experiments)
# CF_PROXY_TUNNEL_HOSTNAME=vkara-prx.example.giang.io.vn
# PLAYWRIGHT_PROXY_USERNAME=vkara
# PLAYWRIGHT_PROXY_PASSWORD=

# VKARA_AIO=1
# GOOGLE_SITE_VERIFICATION=
# ANALYZE=true

# WHISPER_URL=
# HF_TOKEN=
