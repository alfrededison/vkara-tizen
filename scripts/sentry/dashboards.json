            {
              "name": "requests",
              "fields": ["count()"],
              "aggregates": ["count()"],
              "columns": ["project"],
              "fieldAliases": ["", "project"],
              "conditions": "is_transaction:true span.op:http.server",
              "orderby": "-count()"
            }
          ]
        },
        {
          "title": "p95 latency by route",
          "description": "Slowest endpoints first — latency budget",
          "displayType": "table",
          "widgetType": "spans",
          "interval": "5m",
          "layout": { "x": 0, "y": 3, "w": 3, "h": 3, "minH": 2 },
          "queries": [
            {
              "name": "",
              "fields": ["transaction", "count()", "p50(span.duration)", "p95(span.duration)"],
              "aggregates": ["count()", "p50(span.duration)", "p95(span.duration)"],
              "columns": ["transaction"],
              "fieldAliases": ["Route", "Count", "p50", "p95"],
              "conditions": "is_transaction:true span.op:http.server !transaction:OPTIONS*",
              "orderby": "-p95(span.duration)"
