          ]
        },
        {
          "title": "Top unresolved issues",
          "description": "What to fix next — frequency × freshness",
          "displayType": "table",
          "widgetType": "issue",
          "interval": "5m",
          "layout": { "x": 3, "y": 3, "w": 3, "h": 3, "minH": 2 },
          "queries": [
            {
              "name": "",
              "fields": ["issue", "title", "project", "count()", "last_seen()"],
              "aggregates": [],
              "columns": [],
              "fieldAliases": [],
              "conditions": "is:unresolved",
              "orderby": "date"
            }
          ]
        },
        {
          "title": "Warn + error logs",
          "description": "Operational noise / early warning (Winston→Sentry)",
