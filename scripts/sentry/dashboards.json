              "columns": ["severity"],
              "fieldAliases": [],
              "conditions": "severity:warn OR severity:error OR severity:fatal",
              "orderby": "-count()"
            }
          ]
        },
        {
          "title": "Redis + DB spans",
          "description": "Saturation proxy — datastore pressure",
          "displayType": "line",
          "widgetType": "spans",
          "interval": "5m",
